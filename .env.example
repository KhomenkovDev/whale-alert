# Django
DEBUG=True
SECRET_KEY=change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis (required for Channels in production + Celery)
REDIS_URL=redis://localhost:6379

# Channel Layer: "memory" (default, dev) or "redis" (production with multiple workers)
CHANNEL_LAYER_TYPE=memory

# Database (default: SQLite)
DATABASE_URL=sqlite:///db.sqlite3

# RPC Endpoints — replace with your own keys
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BNB_RPC_URL=https://bsc-dataseed.binance.org/
POLYGON_RPC_URL=https://polygon-rpc.com/
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Whale Threshold (default $1M)
WHALE_THRESHOLD_USD=1000000

# AI Reports (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Rate Limiting
AI_REPORT_RATE_LIMIT=10/hour
